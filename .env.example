# ===========================================
# Cursor Chat Archive - 環境変数テンプレート
# ===========================================
# 使い方:
#   1. このファイルを .env にコピー（またはルートの .env を編集）
#   2. 各値を設定
#   3. npm run setup で確認
#   4. npm run db:push（初回のみ）
#   5. npm run dev

# Neon Postgres 接続文字列
# Vercel → Settings → Environment Variables → DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ログイン用パスワード（自分だけの合言葉）
MY_APP_PASSWORD="your-secret-password"

# セッション Cookie 署名用（16文字以上のランダム文字列）
# 例: openssl rand -base64 32
AUTH_SECRET="your-random-secret-at-least-16-chars"

# 以下は任意（現時点では未使用）
# BLOB_READ_WRITE_TOKEN=""
